	email = jlvallelonga@gmail.com
	name = Justin Vallelonga
[core]
	excludesfile = ~/.gitignore_global
	editor = vim
[pager]
	branch = false
[pull]
	rebase = false
[include]
    path = ~/.gitconfig_private
[color]
	ui = true
[color "status"]
	branch = green
[init]
	defaultBranch = main
[mergetool "vscode"]
	cmd = code --wait --merge $REMOTE $LOCAL $BASE $MERGED
